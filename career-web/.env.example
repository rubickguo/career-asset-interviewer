DEEPSEEK_API_KEY=replace-with-your-local-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Public origin used by cookies and callback URLs.
# Local: http://127.0.0.1:5174
# Production example: https://www.lovexb.ltd
APP_ORIGIN=http://127.0.0.1:5174

# Login/session isolation. Set AUTH_REQUIRE_LOGIN=true when exposing the app to real users.
AUTH_REQUIRE_LOGIN=false
AUTH_SESSION_SECRET=replace-with-a-long-random-string
AUTH_COOKIE_NAME=career_web_auth
AUTH_COOKIE_SECURE=false

# Phone login + Aliyun SMS.
PHONE_LOGIN_ENABLED=true
SMS_CODE_TTL_SECONDS=600
SMS_CODE_RESEND_SECONDS=60

# Local development only: when Aliyun SMS is not configured, the backend returns this code.
SMS_DEV_LOGIN_ENABLED=true
SMS_DEV_CODE=123456

# Production SMS config. Do not commit real values.
# Recommended for individual accounts: aliyun_verify uses Aliyun "短信认证服务",
# with the free system sign/template shown in the console.
ALIYUN_SMS_PROVIDER=aliyun_verify
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_TEMPLATE_PARAM={"code":"##code##","min":"10"}
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dypnsapi.aliyuncs.com

# Legacy local fallback login. Keep false unless debugging auth internals.
AUTH_DEV_LOGIN_ENABLED=false
