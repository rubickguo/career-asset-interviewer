{
  "name": "career-asset-interviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "career-web"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "dev": "npm run dev --workspace=hijob",
